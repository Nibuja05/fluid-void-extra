{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Factorio: Prepare local mod",
			"type": "process",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"Set-Content -Encoding UTF8 -LiteralPath '${workspaceFolder}\\mod-list.json' -Value '{\"mods\":[{\"name\":\"base\",\"enabled\":true},{\"name\":\"fluid-void-extra\",\"enabled\":true}]}'"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "Factorio: Run without debugger",
			"type": "process",
			"dependsOn": "Factorio: Prepare local mod",
			"command": "z:\\SteamLibrary\\steamapps\\common\\Factorio\\bin\\x64\\factorio.exe",
			"args": [
				"--mod-directory",
				"${workspaceFolder}",
				"--disable-migration-window"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "Factorio: Validate mod load",
			"type": "process",
			"dependsOn": "Factorio: Prepare local mod",
			"command": "z:\\SteamLibrary\\steamapps\\common\\Factorio\\bin\\x64\\factorio.exe",
			"args": [
				"--mod-directory",
				"${workspaceFolder}",
				"--disable-migration-window",
				"--dump-data",
				"--console-log",
				"${workspaceFolder}\\factorio-validate.log"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			}
		}
	]
}
